<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Register Clinic"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clinic Name"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etClinicName"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input"
            android:hint="e.g. Hope Medical Clinic"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <!-- Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etClinicAddress"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input"
            android:hint="e.g. 123 Health Ave, Cebu City"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp"
            android:inputType="textPostalAddress"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <!-- Phone Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etClinicPhone"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input"
            android:hint="e.g. +63 912 345 6789"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp"
            android:inputType="phone"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etClinicDesc"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_input"
            android:hint="Tell patients about your clinic, services, etc..."
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="12dp" />

        <!-- Hours Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Opening Time"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etClinicOpen"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input"
                    android:hint="08:00 AM"
                    android:text="08:00 AM"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:maxLines="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Closing Time"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etClinicClose"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input"
                    android:hint="05:00 PM"
                    android:text="05:00 PM"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackground"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnCreate"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_primary"
                android:text="Register"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
